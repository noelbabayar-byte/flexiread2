# ========================================================================
# FlexiRead Environment Variables Example
# Copy this file to .env and modify as needed
# ========================================================================

# App Configuration
APP_NAME=FlexiRead
APP_ENV=development
DEBUG=True
LOG_LEVEL=DEBUG

# Database Configuration
DB_USER=flexiread
DB_PASSWORD=flexiread_dev_password
DB_NAME=flexiread
DB_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=flexiread_redis_dev
REDIS_DB=0

# JWT & Authentication
# Generate a secret key using: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-min-32-chars-long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AWS S3 / MinIO Configuration
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=flexiread-dev
AWS_S3_REGION=us-east-1
AWS_S3_INTERNAL_ENDPOINT_URL=http://minio:9000
AWS_S3_PUBLIC_ENDPOINT_URL=http://localhost:9000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# PDF Processing
OCR_ENABLED=True
OCR_LANGUAGE=tur,eng
MAX_PDF_SIZE_MB=150

# Compatibility aliases documented for local tooling
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
S3_BUCKET_NAME=flexiread-dev
S3_CONTENT_BUCKET=flexiread-content
